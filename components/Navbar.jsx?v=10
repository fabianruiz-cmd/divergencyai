// components/Navbar.jsx — logo blanco, nav uniforme, mega-menu hover-stable, filter bar, preview hover
const { useState, useEffect, useRef, useMemo } = React;

function Navbar({ activePage = "inicio" }) {
  const [theme, setTheme] = useState(() =>
  document.documentElement.getAttribute("data-theme") || "dark"
  );
  const [hidden, setHidden] = useState(false);
  const [filterHidden, setFilterHidden] = useState(false);
  const [megaOpen, setMegaOpen] = useState(false);
  const [hoverPreview, setHoverPreview] = useState(null); // 'inicio' | 'lista' | 'pensamos' | 'quienes' | category
  const lastY = useRef(0);
  const closeTimer = useRef(null);

  useEffect(() => {
    document.documentElement.setAttribute("data-theme", theme);
    try {localStorage.setItem("dvg-theme", theme);} catch (e) {}
  }, [theme]);

  useEffect(() => {
    const onScroll = () => {
      const y = window.scrollY;
      const dy = y - lastY.current;
      if (y > 600 && dy > 8) setHidden(true);else
      if (dy < -4 || y < 400) setHidden(false);
      // filter bar disappears once banner scrolled past
      setFilterHidden(y > 480);
      lastY.current = y;
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    return () => window.removeEventListener("scroll", onScroll);
  }, []);

  const openMega = () => {
    if (closeTimer.current) clearTimeout(closeTimer.current);
    setMegaOpen(true);
  };
  const scheduleCloseMega = () => {
    if (closeTimer.current) clearTimeout(closeTimer.current);
    closeTimer.current = setTimeout(() => setMegaOpen(false), 220);
  };

  const categories = window.PORTFOLIO_CATEGORIES || [];
  const products = window.PORTFOLIO || [];

  // Section preview metadata (banner + descripción corta)
  const sectionPreviews = {
    inicio: {
      title: "Inicio",
      blurb: "IA que actúa, no promete. Soluciones aplicadas, listas para producción.",
      tone: "var(--cyan)"
    },
    lista: {
      title: "Lo que hacemos",
      blurb: "20+ productos de IA en 6 categorías. Desde pruebas psicométricas hasta agentes en WhatsApp.",
      tone: "var(--cyan)"
    },
    pensamos: {
      title: "Lo que pensamos",
      blurb: "Notas, casos y opiniones sobre IA aplicada al trabajo real.",
      tone: "#A78BFA"
    },
    quienes: {
      title: "Quiénes somos",
      blurb: "Un estudio de producto enfocado en IA que se queda funcionando después del lanzamiento.",
      tone: "#F59E0B"
    }
  };

  return (
    <>
      <nav className="nav" data-hidden={hidden}>
        <div className="nav__top">
          <a href="index.html" className="nav__logo" aria-label="Inicio Divergency AI">
            <img
              src="assets/logo-white.png"
              alt="Divergency AI"
              className="nav__logo-img" style={{ objectFit: "contain", width: "105px", height: "26px", padding: "0px", margin: "0px", borderWidth: "0px", borderStyle: "solid" }} />
            
          </a>

          <div className="nav__links">
            <a
              href="index.html"
              className="nav__link"
              aria-current={activePage === "inicio" ? "page" : undefined}
              onMouseEnter={() => setHoverPreview('inicio')}
              onMouseLeave={() => setHoverPreview(null)}>
              
              Inicio
            </a>

            <div
              className="nav__mega-wrap"
              onMouseEnter={() => {openMega();setHoverPreview('lista');}}
              onMouseLeave={() => {scheduleCloseMega();setHoverPreview(null);}}>
              
              <button
                className="nav__link nav__link--trigger"
                aria-current={activePage === "lista" ? "page" : undefined}
                aria-expanded={megaOpen}
                onClick={() => setMegaOpen((o) => !o)}>
                
                Lo que hacemos
                <svg width="10" height="10" viewBox="0 0 12 12" style={{
                  marginLeft: 6,
                  transform: megaOpen ? 'rotate(180deg)' : 'none',
                  transition: 'transform .25s'
                }}>
                  <path d="M2 4l4 4 4-4" stroke="currentColor" strokeWidth="1.5" fill="none" strokeLinecap="round" />
                </svg>
              </button>

              <div
                className="nav__mega"
                data-open={megaOpen}
                onMouseEnter={openMega}
                onMouseLeave={scheduleCloseMega}>
                
                <div className="nav__mega-grid">
                  <div className="nav__mega-col">
                    <div className="nav__mega-title">Categorías</div>
                    {categories.filter((c) => c.id !== "todos").map((c) =>
                    <a
                      key={c.id}
                      href={`index.html#portafolio?cat=${encodeURIComponent(c.id)}`}
                      className="nav__mega-item"
                      onMouseEnter={() => setHoverPreview('cat:' + c.id)}
                      onClick={(e) => {
                        // Same-page anchor: trigger filter and scroll
                        if (window.location.pathname.endsWith('index.html') || window.location.pathname.endsWith('/') || window.location.pathname === '') {
                          e.preventDefault();
                          window.dispatchEvent(new CustomEvent('dvg:setCategory', { detail: c.id }));
                          const t = document.getElementById('portafolio');
                          if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
                          setMegaOpen(false);
                        }
                      }}>
                      
                        <span className="nav__mega-item-name">{c.nombre}</span>
                        <span className="nav__mega-item-count">{c.count}</span>
                      </a>
                    )}
                  </div>
                  <div className="nav__mega-col">
                    <div className="nav__mega-title">Destacados</div>
                    {products.slice(0, 5).map((p) =>
                    <a
                      key={p.id}
                      href={`producto.html?id=${p.id}`}
                      className="nav__mega-item">
                      
                        <span className="nav__mega-item-dot" style={{ background: p.color }} />
                        <span className="nav__mega-item-name">{p.nombre}</span>
                      </a>
                    )}
                  </div>
                  <div className="nav__mega-col nav__mega-col--cta">
                    <div className="nav__mega-title">Portafolio</div>
                    <p className="nav__mega-blurb">{products.length} productos de IA aplicada, filtrables por categoría y por tipo de solución.</p>
                    <a href="lista.html" className="btn-ghost btn-ghost--sm">
                      Ver todo
                      <svg width="12" height="9" viewBox="0 0 14 10"><path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" strokeWidth="1.5" fill="none" /></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <a
              href="index.html#pensamos"
              className="nav__link"
              aria-current={activePage === "pensamos" ? "page" : undefined}
              onMouseEnter={() => setHoverPreview('pensamos')}
              onMouseLeave={() => setHoverPreview(null)}>
              
              Lo que pensamos
            </a>
            <a
              href="quienes-somos.html"
              className="nav__link"
              aria-current={activePage === "quienes" ? "page" : undefined}
              onMouseEnter={() => setHoverPreview('quienes')}
              onMouseLeave={() => setHoverPreview(null)}>
              
              Quiénes somos
            </a>
          </div>

          <div style={{ display: "flex", gap: 12, alignItems: "center" }}>
            <SearchBar />
            <button
              className="nav__theme"
              onClick={() => setTheme((t) => t === "dark" ? "light" : "dark")}
              title={theme === "dark" ? "Modo iluminado" : "Modo oscuro"}
              aria-label="Cambiar tema">
              
              {theme === "dark" ?
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" stroke="currentColor" strokeWidth="1.4" /><path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M2.6 2.6l1.06 1.06M12.34 12.34l1.06 1.06M2.6 13.4l1.06-1.06M12.34 3.66l1.06-1.06" stroke="currentColor" strokeWidth="1.4" strokeLinecap="round" /></svg> :

              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M13.5 9.5A5.5 5.5 0 0 1 6.5 2.5a5.5 5.5 0 1 0 7 7Z" stroke="currentColor" strokeWidth="1.4" strokeLinejoin="round" /></svg>
              }
            </button>
            <a href="#contacto" className="nav__cta">
              Te contactamos
              <svg width="14" height="10" viewBox="0 0 14 10"><path d="M1 5h12M9 1l4 4-4 4" stroke="currentColor" strokeWidth="1.6" fill="none" strokeLinecap="round" strokeLinejoin="round" /></svg>
            </a>
          </div>
        </div>

        {/* Hover preview banner */}
        <div className="nav__preview" data-show={!!hoverPreview && (!!sectionPreviews[hoverPreview] || hoverPreview.startsWith('cat:'))}>
          {hoverPreview && sectionPreviews[hoverPreview] &&
          <div className="nav__preview-inner">
              <span className="nav__preview-dot" style={{ background: sectionPreviews[hoverPreview].tone }} />
              <span className="nav__preview-title">{sectionPreviews[hoverPreview].title}</span>
              <span className="nav__preview-sep">·</span>
              <span className="nav__preview-blurb">{sectionPreviews[hoverPreview].blurb}</span>
            </div>
          }
          {hoverPreview && hoverPreview.startsWith('cat:') && (() => {
            const id = hoverPreview.slice(4);
            const cat = categories.find((c) => c.id === id);
            const sample = products.filter((p) => p.categoria === id).slice(0, 3);
            if (!cat) return null;
            return (
              <div className="nav__preview-inner">
                <span className="nav__preview-dot" style={{ background: 'var(--cyan)' }} />
                <span className="nav__preview-title">{cat.nombre}</span>
                <span className="nav__preview-sep">·</span>
                <span className="nav__preview-blurb">
                  {cat.count} productos. {sample.map((p) => p.nombre).join(' · ')}
                </span>
              </div>);

          })()}
        </div>

        {/* Filter bar (categorías) — vive dentro del nav, solo en home */}
        {activePage === 'inicio' &&
        <div className="navfilter" data-hidden={filterHidden}>
            <div className="navfilter__inner">
              <span className="navfilter__label">Filtrar por:</span>
              {categories.map((c) =>
            <a
              key={c.id}
              href={`#portafolio?cat=${encodeURIComponent(c.id)}`}
              className="navfilter__chip"
              onClick={(e) => {
                e.preventDefault();
                window.dispatchEvent(new CustomEvent('dvg:setCategory', { detail: c.id }));
                const t = document.getElementById('portafolio');
                if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }}>
              
                  {c.nombre} <span className="navfilter__count">{c.count}</span>
                </a>
            )}
            </div>
          </div>
        }
      </nav>
    </>);

}

function SearchBar() {
  const [q, setQ] = useState("");
  const [open, setOpen] = useState(false);
  const wrapRef = useRef(null);

  useEffect(() => {
    const onClick = (e) => {
      if (wrapRef.current && !wrapRef.current.contains(e.target)) setOpen(false);
    };
    document.addEventListener("click", onClick);
    return () => document.removeEventListener("click", onClick);
  }, []);

  const results = useMemo(() => {
    if (!q.trim()) return [];
    const norm = q.toLowerCase().trim();
    return (window.PORTFOLIO || []).filter((p) =>
    p.nombre.toLowerCase().includes(norm) ||
    p.blurb.toLowerCase().includes(norm) ||
    p.categoria.toLowerCase().includes(norm) ||
    (p.tipo || "").toLowerCase().includes(norm)
    ).slice(0, 8);
  }, [q]);

  return (
    <div ref={wrapRef} style={{ position: "relative" }}>
      <div className="nav__search">
        <svg className="nav__search-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <circle cx="6" cy="6" r="4.5" stroke="currentColor" strokeWidth="1.3" />
          <path d="m9.5 9.5 3 3" stroke="currentColor" strokeWidth="1.3" strokeLinecap="round" />
        </svg>
        <input
          type="text"
          placeholder="Buscar productos, servicios…"
          value={q}
          onChange={(e) => {setQ(e.target.value);setOpen(true);}}
          onFocus={() => setOpen(true)} />
        
        {!q && <span className="nav__search-kbd">⌘K</span>}
      </div>
      {open && q.trim() &&
      <div className="search-results">
          {results.length === 0 ?
        <div className="search-empty">Sin resultados para "{q}"</div> :
        results.map((p) =>
        <a key={p.id} className="search-result" href={`producto.html?id=${p.id}`}>
              <span className="search-result__dot" style={{ background: p.color }} />
              <div>
                <div className="search-result__name">{p.nombre}</div>
              </div>
              <span className="search-result__cat">{p.categoria}</span>
            </a>
        )}
        </div>
      }
    </div>);

}

window.Navbar = Navbar;